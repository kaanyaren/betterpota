---
// Map component that initializes the Leaflet map
---

<!-- Map container -->
<div id="map"></div>

<!-- Load Leaflet CSS from jsdelivr -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />

<!-- Load scripts -->
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
<script is:inline src="/betterpota/map.js?v=15"></script>

<!-- Initialize with polling -->
<script is:inline>
  (function() {
    var attempts = 0;
    var maxAttempts = 30;
    var interval = setInterval(function() {
      attempts++;
      if (typeof window.initMap === 'function' && typeof L !== 'undefined' && L.map) {
        clearInterval(interval);
        try {
          window.initMap();
        } catch(e) {
          console.error('initMap error:', e);
        }
      } else if (attempts >= maxAttempts) {
        clearInterval(interval);
        console.log('Timeout - L:', typeof L, 'initMap:', typeof window.initMap);
      }
    }, 100);
  })();
</script>