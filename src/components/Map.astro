---
// Map component that initializes the Leaflet map
---

<!-- Map container -->
<div id="map"></div>

<!-- Load Leaflet and MarkerCluster CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

<!-- Load scripts - direct tags for reliability -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.min.js"></script>
<script is:inline src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.min.js"></script>
<script is:inline src="/betterpota/map.js?v=7"></script>

<!-- Auto-init map after scripts load -->
<script is:inline>
  function initMapCallback() {
    if (typeof window.initMap === 'function') {
      window.initMap();
    } else if (typeof L !== 'undefined' && L.map) {
      // Fallback: init directly if initMap not available yet
      setTimeout(initMapCallback, 100);
    }
  }
  // Try to init immediately, then retry
  initMapCallback();
  setTimeout(initMapCallback, 1000);
</script>