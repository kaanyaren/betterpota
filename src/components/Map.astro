---
// Map component that initializes the Leaflet map
---

<!-- Map container -->
<div id="map"></div>

<!-- Load Leaflet CSS from jsdelivr -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />

<!-- Load scripts -->
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js"></script>
<script is:inline type="module" src="/betterpota/convex-client.js"></script>
<script is:inline src="/betterpota/map.js?v=24"></script>

<!-- Initialize map after page load -->
<script is:inline>
  window.addEventListener('load', function() {
    console.log('Page loaded, checking for L and initMap');
    if (typeof L !== 'undefined' && typeof window.initMap === 'function') {
      console.log('L and initMap available, initializing map');
      window.initMap();
    } else {
      console.log('Waiting for L and initMap...');
      var attempts = 0;
      var maxAttempts = 50;
      var interval = setInterval(function() {
        attempts++;
        if (typeof L !== 'undefined' && typeof window.initMap === 'function') {
          clearInterval(interval);
          console.log('L and initMap available after', attempts, 'attempts');
          window.initMap();
        } else if (attempts >= maxAttempts) {
          clearInterval(interval);
          console.error('Timeout - L:', typeof L, 'initMap:', typeof window.initMap);
        }
      }, 100);
    }
  });
</script>